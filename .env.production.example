# ──────────────────────────────────────────────────────────────────────
# EDUINTBD production environment template
#
# Paste these into Vercel → Settings → Environment Variables (Production).
# Replace every placeholder marked <...>. Anything that already has a
# value below is a reasonable default you can keep or change.
# ──────────────────────────────────────────────────────────────────────

# Postgres (Neon pooled connection string — the one with -pooler in the host).
DATABASE_URL=<neon-pooled-connection-string>

# NextAuth
NEXTAUTH_URL=https://eduintbd.com
# Generate your own 32-byte hex (do NOT reuse any value committed to git).
#   Run:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=<generate-fresh-32-byte-hex>

# Google OAuth
# Redirect URI to add in Google Cloud Console:
#   https://eduintbd.com/api/auth/callback/google
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>

# Anthropic (Claude API) — used by /chat, SOP review, IELTS + visa mocks
ANTHROPIC_API_KEY=<anthropic-api-key>

# WhatsApp floating button + internal alert deep-links
# Digits only, country code included. E.g. 8801700000000
NEXT_PUBLIC_WHATSAPP_NUMBER=<bd-number>
WHATSAPP_INTERNAL_NUMBER=<bd-number>

# Meta Pixel (optional)
NEXT_PUBLIC_META_PIXEL_ID=1347454903743648

# Email — Resend
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=EDUINTBD <notifications@eduintbd.com>
# Internal inbox that gets new-lead / new-booking / event-register alerts
LEADS_EMAIL_TO=admissions@eduintbd.com

# Storage — left disabled for v1. Set STORAGE_DRIVER=disabled explicitly
# so uploads return a clean 503 with instructions to email documents.
STORAGE_DRIVER=disabled
