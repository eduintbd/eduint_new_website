# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic Claude API
ANTHROPIC_API_KEY=""

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=""

# WhatsApp (Phase 1 lead capture — digits only, include country code)
NEXT_PUBLIC_WHATSAPP_NUMBER="8801700000000"
# Internal number for outbound lead/booking deep-links (optional, defaults to NEXT_PUBLIC_WHATSAPP_NUMBER)
WHATSAPP_INTERNAL_NUMBER="8801700000000"

# Email notifications (Phase 2)
# If RESEND_API_KEY is unset, emails are logged to the server console (dev).
RESEND_API_KEY=""
EMAIL_FROM="EDUINTBD <notifications@eduintbd.ai>"
# Internal inbox that receives new-lead / new-booking alerts
LEADS_EMAIL_TO="admissions@eduintbd.ai"
